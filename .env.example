# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="RideSync+"
APP_VERSION="1.0.0"
APP_ENV="development"          # development | staging | production
DEBUG=true

# ── API ───────────────────────────────────────────────────────────────────────
API_V1_PREFIX="/api/v1"
BACKEND_CORS_ORIGINS='["http://localhost:3000","http://localhost:8080"]'

# ── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY="CHANGE_ME_use_openssl_rand_hex_32_in_production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=ridesync
POSTGRES_PASSWORD=ridesync_dev_password
POSTGRES_DB=ridesync_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
RIDE_CACHE_TTL_SECONDS=30     # ride data cache lifetime

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL="redis://localhost:6379/1"
CELERY_RESULT_BACKEND="redis://localhost:6379/2"

# ── Ride-Hailing Platforms ────────────────────────────────────────────────────
# When real API keys are available, populate these.
# The system uses simulated data by default.
UBER_API_KEY=""
BOLT_API_KEY=""
YANGO_API_KEY=""

# ── Analytics ────────────────────────────────────────────────────────────────
SURGE_THRESHOLD_MULTIPLIER=1.3   # 30% above baseline = surge
PREDICTION_HISTORY_DAYS=30       # days of history for surge model
